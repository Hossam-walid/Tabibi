generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  emailVerified  Boolean       @default(false)
  name           String?
  phone          String?
  image          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  role           Role          @default(MEMBER)
  organizationId String?
  crmTasks       CrmTask[]
  doctors        Doctor[]      @relation("UserToDoctor")
  patients       Patient[]     @relation("UserToPatient")
  accounts       Account[]
  invitations    Invitation[]
  memberships    Member[]
  sessions       Session[]
  notifications  Notification[]
  sentMessages   Message[]
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([organizationId])
  @@map("user")

}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  providerId            String
  accountId             String
  password              String?
  refresh_token         String?
  access_token          String?
  expires_at            Int?
  token_type            String?
  scope                 String?
  id_token              String?
  session_state         String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Session {
  id                   String   @id @default(cuid())
  token                String   @unique
  userId               String
  expiresAt            DateTime
  ipAddress            String?
  userAgent            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  activeOrganizationId String?
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expires    DateTime
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([identifier])
  @@map("verification")
}

model Organization {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  logo           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  metadata       String?
  appointments   Appointment[]
  crmTasks       CrmTask[]
  doctors        Doctor[]
  reviews        DoctorReview[]
  integrations   Integration[]
  labs           Lab[]
  patientRecords PatientRecord[]
  pharmacies     Pharmacy[]
  prescriptions  Prescription[]
  referrals      Referral[]
  invitations    Invitation[]
  members        Member[]
  users          User[]
  patients       Patient[]

  @@index([slug])
  @@map("organization")
}

model Member {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("member")
}

model Patient {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  userId         String          @unique
  organizationId String?
  firstName      String
  lastName       String?
  email          String?
  phone         String?
  dateOfBirth   DateTime?
  gender        Gender?
  address      String?
  city          String?
  state         String?
  pincode      String?
  bloodGroup   String?
  allergies   String?
  medicalHistory String?
  appointments Appointment[]
  reviews      DoctorReview[]
  patientRecords PatientRecord[]
  prescriptions Prescription[]
  referrals     Referral[]
  user          User            @relation("UserToPatient", fields: [userId], references: [id])
  organization  Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

model Doctor {
  id             String               @id @default(cuid())
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  userId         String
  organizationId String
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  specialization String
  qualification  String?
  experience     Int?
  bio            String?
  fees           Decimal?             @db.Decimal(10, 2)
  image          String?
  isAvailable    Boolean              @default(true)
  appointments   Appointment[]
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                 @relation("UserToDoctor", fields: [userId], references: [id])
  availabilities DoctorAvailability[]
  reviews        DoctorReview[]
  patientRecords PatientRecord[]
  prescriptions  Prescription[]

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@index([specialization])
}

model DoctorAvailability {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  doctorId  String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean      @default(true)
  doctor    Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  slots     DoctorSlot[]

  @@index([doctorId])
}

model DoctorSlot {
  id             String             @id @default(cuid())
  createdAt      DateTime           @default(now())
  availabilityId String
  date           DateTime
  startTime      String
  endTime        String
  isBooked       Boolean            @default(false)
  availability   DoctorAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

  @@index([availabilityId])
  @@index([date])
}

model Appointment {
  id                 String               @id @default(cuid())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  patientId          String
  doctorId           String
  organizationId     String
  createdByUserId    String
  appointmentDate    DateTime
  startTime          String
  endTime            String
  status             AppointmentStatus    @default(PENDING)
  type               AppointmentType      @default(CHECKUP)
  reason             String?
  notes              String?
  cancellationReason String?
  slotId             String?              @unique
  paymentStatus      PaymentStatus        @default(PENDING)
  paymentId          String?
  paymentAmount      Decimal?             @db.Decimal(10, 2)
  rating             Int?
  paymentMethod      String?
  paymentProof       String?
  doctor             Doctor               @relation(fields: [doctorId], references: [id])
  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient            Patient              @relation(fields: [patientId], references: [id])
  history            AppointmentHistory[]
  messages           Message[]
  review             DoctorReview?

  @@index([patientId])
  @@index([doctorId])
  @@index([organizationId])
  @@index([appointmentDate])
  @@index([status])
}

model AppointmentHistory {
  id              String            @id @default(cuid())
  createdAt       DateTime          @default(now())
  appointmentId   String
  status          AppointmentStatus
  notes           String?
  changedByUserId String
  appointment     Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
}

model DoctorReview {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  rating         Int
  comment        String?
  doctorId       String
  patientId      String
  appointmentId  String       @unique
  organizationId String
  appointment    Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor         Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([patientId])
  @@index([organizationId])
}

model PatientRecord {
  id             String         @id @default(cuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  patientId      String
  doctorId       String
  organizationId String
  visitDate      DateTime
  chiefComplaint String?
  diagnosis      String?
  notes          String?
  vitalSigns     String?
  attachments    String[]
  doctor         Doctor         @relation(fields: [doctorId], references: [id])
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient        Patient        @relation(fields: [patientId], references: [id])
  prescriptions  Prescription[]
  referrals      Referral[]

  @@index([patientId])
  @@index([doctorId])
  @@index([organizationId])
}

model Prescription {
  id             String             @id @default(cuid())
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  patientId      String
  doctorId       String
  recordId       String?
  organizationId String
  status         PrescriptionStatus @default(DRAFT)
  medicines      String
  notes          String?
  followUpDate   DateTime?
  doctor         Doctor             @relation(fields: [doctorId], references: [id])
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient        Patient            @relation(fields: [patientId], references: [id])
  record         PatientRecord?     @relation(fields: [recordId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@index([organizationId])
}

model Referral {
  id             String         @id @default(cuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  patientId      String
  recordId       String?
  organizationId String
  type           ReferralType
  pharmacyId     String?
  labId          String?
  notes          String?
  status         ReferralStatus @default(PENDING)
  lab            Lab?           @relation(fields: [labId], references: [id])
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patient        Patient        @relation(fields: [patientId], references: [id])
  pharmacy       Pharmacy?      @relation(fields: [pharmacyId], references: [id])
  record         PatientRecord? @relation(fields: [recordId], references: [id])

  @@index([patientId])
  @@index([organizationId])
}

model Pharmacy {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  pincode        String?
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  referrals      Referral[]

  @@index([organizationId])
}

model Lab {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  pincode        String?
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  referrals      Referral[]

  @@index([organizationId])
}

model CrmTask {
  id               String        @id @default(cuid())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  organizationId   String
  assignedToUserId String?
  title            String
  description      String?
  status           CrmTaskStatus @default(OPEN)
  priority         Priority      @default(MEDIUM)
  dueDate          DateTime?
  patientName      String?
  assignedToUser   User?         @relation(fields: [assignedToUserId], references: [id])
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([assignedToUserId])
  @@index([status])
}

model Integration {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organizationId String
  type           IntegrationType
  name           String
  credentials    String
  isActive       Boolean         @default(true)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncLogs       SyncLog[]
  webhooks       Webhook[]

  @@index([organizationId])
}

model Webhook {
  id            String            @id @default(cuid())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  integrationId String
  url           String
  events        String[]
  secret        String?
  isActive      Boolean           @default(true)
  integration   Integration       @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  deliveries    WebhookDelivery[]

  @@index([integrationId])
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  webhookId    String
  status       String
  statusCode   Int?
  requestBody  String
  responseBody String?
  error        String?
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
}

model SyncLog {
  id               String        @id @default(cuid())
  createdAt        DateTime      @default(now())
  integrationId    String
  status           SyncStatus
  direction        SyncDirection
  recordsProcessed Int?
  recordsFailed    Int?
  error            String?
  integration      Integration   @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
}

model Invitation {
  id             String       @id
  organizationId String
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  DOCTOR
  RECEPTIONIST
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
  DOCTOR
  RECEPTIONIST
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  CHECKUP
  FOLLOWUP
  EMERGENCY
  CONSULTATION
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  VERIFYING
}

enum PrescriptionStatus {
  DRAFT
  FINALIZED
}

enum ReferralType {
  PHARMACY
  LAB
  RADIOLOGY
}

enum ReferralStatus {
  PENDING
  SENT
  COMPLETED
  EXPIRED
}

enum CrmTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum IntegrationType {
  STRIPE
  RAZORPAY
  CLOUDINARY
  GOOGLE_CALENDAR
  CUSTOM
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum SyncDirection {
  PUSH
  PULL
  BIDIRECTIONAL
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Message {
  id            String      @id @default(cuid())
  appointmentId String
  senderId      String
  content       String
  isRead        Boolean     @default(false)
  createdAt     DateTime    @default(now())

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  sender        User        @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([senderId])
}
